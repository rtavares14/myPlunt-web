generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────────

enum AuthProvider {
  LOCAL
  GOOGLE
  APPLE
}

model User {
  id           String       @id @default(uuid())
  name         String
  username     String       @unique
  email        String       @unique
  password     String?
  authProvider AuthProvider @default(LOCAL)
  providerId   String?
  avatarUrl    String?
  bio          String?
  city         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  plants   Plant[]
  planters Planter[]

  sentRequests     Friendship[] @relation("FriendshipRequester")
  receivedRequests Friendship[] @relation("FriendshipAddressee")

  blockedUsers UserBlock[] @relation("Blocker")
  blockedBy    UserBlock[] @relation("Blocked")

  sentReminders     WateringReminder[] @relation("ReminderSender")
  receivedReminders WateringReminder[] @relation("ReminderReceiver")

  @@map("users")
}

// ─── Plants ──────────────────────────────────────────────

enum Sunlight {
  HIGH
  MEDIUM
  LOW
}

model Plant {
  id                   String    @id @default(uuid())
  ownerId              String
  planterId            String?
  name                 String
  species              String?
  isDead               Boolean   @default(false)
  wateringIntervalDays Int       @default(7)
  sunlight             Sunlight  @default(MEDIUM)
  minTemp              Float?
  maxTemp              Float?
  dateAcquired         DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  owner        User               @relation(fields: [ownerId], references: [id])
  planter      Planter?           @relation(fields: [planterId], references: [id])
  images       PlantImage[]
  wateringLogs WateringLog[]
  reminders    WateringReminder[]

  @@map("plants")
}

// ─── Planters ────────────────────────────────────────────

model Planter {
  id          String   @id @default(uuid())
  ownerId     String
  name        String
  description String?
  isIndoor    Boolean  @default(true)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner  User    @relation(fields: [ownerId], references: [id])
  plants Plant[]

  @@map("planters")
}

// ─── Watering Log ────────────────────────────────────────

model WateringLog {
  id        String   @id @default(uuid())
  plantId   String
  notes     String?
  wateredAt DateTime @default(now())
  createdAt DateTime @default(now())

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("watering_logs")
}

// ─── Plant Images ────────────────────────────────────────

model PlantImage {
  id        String   @id @default(uuid())
  plantId   String
  url       String
  createdAt DateTime @default(now())

  plant Plant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("plant_images")
}

// ─── Friendships ─────────────────────────────────────────

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  sentAt      DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id])
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
  @@map("friendships")
}

// ─── User Blocks ─────────────────────────────────────────

model UserBlock {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  blockedAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id])
  blocked User @relation("Blocked", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
  @@map("user_blocks")
}

// ─── Watering Reminders ──────────────────────────────────

model WateringReminder {
  id         String    @id @default(uuid())
  senderId   String
  receiverId String
  plantId    String
  message    String?
  sentAt     DateTime  @default(now())
  readAt     DateTime?

  sender   User  @relation("ReminderSender", fields: [senderId], references: [id])
  receiver User  @relation("ReminderReceiver", fields: [receiverId], references: [id])
  plant    Plant @relation(fields: [plantId], references: [id])

  @@map("watering_reminders")
}
